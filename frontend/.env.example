# Frontend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===================================
# API SERVER CONFIGURATION
# ===================================
VITE_SERVER_URL=http://localhost:5000/
VITE_API_URL=http://localhost:5000/api/

# ===================================
# PRODUCTION URLS (Uncomment for production)
# ===================================
# VITE_SERVER_URL=https://api.dfreebook.vn/
# VITE_API_URL=https://api.dfreebook.vn/api/

# ===================================
# APP CONFIGURATION
# ===================================
VITE_APP_NAME=D Free Book
VITE_APP_VERSION=1.0.0

# ===================================
# FEATURE FLAGS
# ===================================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# ===================================
# OPTIONAL - CLOUDINARY (Image Upload)
# ===================================
# VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ===================================
# OPTIONAL - GOOGLE ANALYTICS
# ===================================
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ===================================
# OPTIONAL - FIREBASE (For real-time features)
# ===================================
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket

# ===================================
# TIMEOUT CONFIGURATION
# ===================================
VITE_API_TIMEOUT=30000
VITE_REQUEST_RETRY_ATTEMPTS=3

# ===================================
# PAGINATION
# ===================================
VITE_ITEMS_PER_PAGE=20
VITE_BOOKS_PER_PAGE=12
VITE_ARTICLES_PER_PAGE=10

# ===================================
# BUILD CONFIGURATION
# ===================================
VITE_BUILD_OUTDIR=dist
VITE_BUILD_ASSETSDIR=assets
