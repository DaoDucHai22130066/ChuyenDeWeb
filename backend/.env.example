# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===================================
# DATABASE CONFIGURATION
# ===================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=library_management
DB_PORT=3306

# ===================================
# SERVER CONFIGURATION
# ===================================
PORT=5000
NODE_ENV=development

# ===================================
# JWT CONFIGURATION
# ===================================
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long_12345678
JWT_EXPIRE=24h

# ===================================
# EMAIL CONFIGURATION (Gmail)
# ===================================
# Generate app password: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_16_digits

# ===================================
# CLOUDINARY CONFIGURATION (Image Upload)
# ===================================
# Get credentials from: https://cloudinary.com
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=dfreebook

# ===================================
# FRONTEND CONFIGURATION (React)
# ===================================
VITE_SERVER_URL=http://localhost:5000/
VITE_API_URL=http://localhost:5000/api/

# ===================================
# OPTIONAL CONFIGURATION
# ===================================
# Enable debug logging
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database connection pool settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_ENABLE_KEEP_ALIVE=true
DB_KEEP_ALIVE_INITIAL_DELAY_MS=0

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# PAYMENT GATEWAY (Optional - for future)
# ===================================
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ===================================
# SMS CONFIGURATION (Optional - for future)
# ===================================
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ===================================
# LOGGING CONFIGURATION (Optional)
# ===================================
# LOG_LEVEL=info
# LOG_FILE_PATH=./logs/app.log
