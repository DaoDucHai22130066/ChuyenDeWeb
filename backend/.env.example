# Backend environment example
# Copy this file to `.env` and fill real secrets (DO NOT commit .env)

PORT=5000
GOOGLE_CLIENT_ID=560711663335-h60v2rojbpdfvhuakukj4pl6pnlivmm6.apps.googleusercontent.com

GOOGLE_CLIENT_SECRET=your_google_client_secret_here
JWT_SECRET=your_jwt_secret_here
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# Database settings (example placeholders)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=your_db_password
DB_NAME=library_db
PORT=5000
JWT_SECRET=your_jwt_secret_key
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=library_db

EMAIL_USER=your_email_address
EMAIL_PASS=your_email_password
GOOGLE_CLIENT_ID=your_google_client_id
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin

# VNPAY sandbox settings for deposit payment
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/tickets/vnpay/return
VNPAY_IPN_URL=http://localhost:5000/tickets/vnpay/ipn
VNPAY_CALLBACK_BASE_URL=http://localhost:5000
VNPAY_ALLOW_LOCALHOST=true
VNPAY_DEBUG=false

JWT_EXPIRES_IN=24h
JWT_ISSUER=DFreeBook
JWT_AUDIENCE=DFreeBook-Web
FRONTEND_URL=http://localhost:5173

# Auth cookie settings
AUTH_COOKIE_NAME=authToken
AUTH_COOKIE_MAX_AGE_MS=86400000
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false

# Public auth rate limits
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
REGISTER_RATE_LIMIT_WINDOW_MS=900000
REGISTER_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW_MS=600000
OTP_RATE_LIMIT_MAX=10
OTP_RESEND_RATE_LIMIT_WINDOW_MS=60000
OTP_RESEND_RATE_LIMIT_MAX=3

# OTP security
OTP_HASH_SECRET=your_otp_hash_secret_here
OTP_MAX_ATTEMPTS=5
OTP_EXPIRY_MINUTES=10
OTP_LOCK_MINUTES=15
OTP_RESEND_COOLDOWN_SECONDS=60
